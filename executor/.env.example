# Vouch executor env — copy to .env (which is gitignored).

# Agent private key. Accepted formats:
#   - suiprivkey1...     (bech32, what `sui keytool export` prints)
#   - 0x...              (raw 32-byte hex secret key)
# If unset, the executor falls back to ~/.sui/sui_config/sui.keystore looking for
# the key matching CONFIG.agent.address (dev convenience only).
AGENT_PRIVATE_KEY=

# HTTP server port for the /run-now demo endpoint.
PORT=8787

# Poll loop interval (ms). 30s mirrors CLAUDE.md §5.
POLL_INTERVAL_MS=30000

# If true, the poll loop is disabled and only the /run-now endpoint executes.
# Useful during demos so the executor doesn't act on its own.
DISABLE_POLL=false
